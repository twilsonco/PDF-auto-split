# API Configuration
API_BASE=http://localhost:8000/v1
API_KEY=
MODEL_NAME=qwen-2.5-vision-72b

# Processing Options
API_TIMEOUT=30
IMAGE_DPI=150

# Vision Model Prompt (for slow path analysis)
VISION_PROMPT="Analyze these two consecutive document pages and determine if they are part of the same continuous document.

Look for:
- Consistent headers, footers, page numbers
- Continued text flow across pages
- Similar formatting and layout
- Thematic continuity

Respond with JSON:
{
  \"is_same_document\": boolean,
  \"confidence\": integer (0-100),
  \"reasoning\": \"string explaining the decision\"
}"